{
  "name": "whatsapp-real-estate-scraper",
  "version": "1.0.0",
  "description": "WhatsApp Real Estate Group Scraper + Dashboard",
  "main": "src/api/server.js",
  "scripts": {
    "start": "node src/api/server.js",
    "dev": "nodemon src/api/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "format": "prettier --write src/",
    "worker:parse": "node src/worker/parseWorker.js",
    "init-db": "node src/db/init.js",
    "migrate": "node src/db/migrate.js",
    "migrate:pg": "node src/db/postgres/migrate.js",
    "scrape": "node src/scraper/whatsapp-scraper.js",
    "parse": "node src/scraper/message-parser.js",
    "test:smoke": "node tests/smoke.js",
    "test:endpoints": "node tests/endpoints.js",
    "test:security": "node tests/security.js",
    "test:db": "node tests/db_integrity.js",
    "test:performance": "node tests/performance.js",
    "test:bulk-insert": "node tests/bulk_insert.js",
    "test:bulk-parse": "node tests/bulk_parse.js",
    "test:audit": "node tests/run_audit.js",
    "test:e2e": "cd dashboard && npx cypress run",
    "test:e2e:open": "cd dashboard && npx cypress open",
    "restore": "bash scripts/restore.sh",
    "restore:verify": "bash scripts/restore.sh --verify-only",
    "backup": "bash scripts/backup.sh"
  },
  "dependencies": {
    "@clerk/express": "^2.1.21",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@upstash/redis": "^1.38.0",
    "@wppconnect-team/wppconnect": "^2.2.1",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "body-parser": "latest",
    "bullmq": "^5.77.3",
    "cookie-parser": "^1.4.7",
    "cors": "latest",
    "dayjs": "latest",
    "dotenv": "latest",
    "express": "latest",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lodash": "latest",
    "lru-cache": "^11.5.1",
    "morgan": "latest",
    "node-cron": "latest",
    "pg": "^8.21.0",
    "prom-client": "^15.1.3",
    "puppeteer": "latest",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "latest",
    "sqlite3": "latest",
    "uuid": "latest",
    "whatsapp-web.js": "latest",
    "winston": "latest"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "eslint": "latest",
    "jest": "^30.4.2",
    "nodemon": "latest",
    "prettier": "latest",
    "supertest": "^7.2.2"
  }
}
