PORT=3000

# Default market — affects parser defaults (location lists, currency, …)
APP_MARKET=dubai

# === Postgres (Neon or self-hosted) ===
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Set to "true" only when connecting to a self-managed Postgres with a known CA.
# Leave unset (defaults to false) for Neon managed service.
# PG_SSL_REJECT_UNAUTHORIZED=true

# === Redis (local or Upstash) ===
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# === LLM layer 1 — Groq (Llama) — sign up at https://console.groq.com ===
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant

# === LLM layer 2 — Gemini 2.0 Flash — https://aistudio.google.com/apikey ===
# Used alongside Groq for consensus parsing (hallucination + misinterpretation reduction)
# Free tier: 15 RPM, 1M tokens/day — sufficient for ~4000 listings/day
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-2.0-flash

# === Clerk Auth — sign up at https://clerk.com ===
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# RSA public key for offline JWT verification (from Clerk dashboard > API Keys > JWT public key)
CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----
...
-----END PUBLIC KEY-----"

# === CORS (optional) ===
# Comma-separated list of additional allowed origins beyond localhost defaults
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# === Redis (docker-compose) ===
# Required for Redis AUTH inside docker-compose. Pick a long random string.
REDIS_PASSWORD=changeme-please-use-a-long-random-string

# === Prometheus metrics ===
# Token required in the X-Metrics-Token header to access /api/v1/metrics.
# Leave unset to disable the endpoint entirely.
METRICS_TOKEN=

# === Clerk authorized parties (production) ===
# Override the localhost defaults in production with your actual origin(s).
# Comma-separated list of origins that legitimately load the app.
# CLERK_AUTHORIZED_PARTIES=https://app.yourdomain.com

# === HMAC secret for bridge IPC signing (multi-instance deployments) ===
# Both the server process and bridge subprocess must agree on this secret
# so their HMAC signatures match. Generate: openssl rand -hex 32
BRIDGE_HMAC_SECRET=

# === OpenTelemetry (optional — leave unset to disable tracing) ===
# OTLP/HTTP collector endpoint. Examples:
#   Local Jaeger:  http://localhost:4318
#   Grafana Cloud: https://otlp-gateway-prod-us-east-0.grafana.net/otlp
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_SERVICE_NAME=property-digest
# OTEL_DISABLED=false

# === Parse worker retry/DLQ tuning ===
# How many failed attempts before a parse job is dead-lettered
# PARSE_MAX_ATTEMPTS=5
# Initial backoff between retries (ms); doubles each attempt
# PARSE_RETRY_BACKOFF_MS=60000
